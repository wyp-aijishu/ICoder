# Default provider used when --provider is omitted.
ICODER_PROVIDER=deepseek

# Long-term memories are project-isolated under this directory.
# Defaults to ~/.icoder/memory when omitted.
ICODER_MEMORY_ROOT=

# DeepSeek OpenAI-compatible configuration.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Zhipu GLM OpenAI-compatible configuration.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
GLM_MODEL=glm-5.1
